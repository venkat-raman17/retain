{
  "cli": {
    "version": ">= 10.0.0",
    "promptToConfigurePushNotifications": false,
    "appVersionSource": "remote"
  },
  "build": {
    "dev": {
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      }
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "credentialsSource": "remote"
      },
      "ios": {
        "credentialsSource": "remote",
        "distribution": "store",
        "autoIncrement": true
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "ios": {
        "credentialsSource": "remote",
        "distribution": "store",
        "autoIncrement": true
      }
    }
  }
}
