# Expo + React Native require a flat (hoisted) node_modules layout so that
# Metro's autolinking and native module resolution behave like npm/yarn.
# pnpm's default symlinked layout breaks React Native, so we opt into hoisting.
node-linker=hoisted

# The RN/Expo ecosystem has many loose peer ranges; don't fail installs on them.
auto-install-peers=true
strict-peer-dependencies=false
